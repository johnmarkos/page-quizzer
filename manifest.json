{
  "manifest_version": 3,
  "name": "PageQuizzer",
  "version": "0.1.0",
  "description": "Generate quiz questions from any web page for retrieval practice",
  "permissions": ["sidePanel", "activeTab", "storage", "scripting", "tabs", "contextMenus"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost:11434/*",
    "file:///*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/pdfjs.js", "dist/pdf.worker.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/panel/panel.html"
  },
  "action": {
    "default_title": "PageQuizzer"
  },
  "icons": {}
}
